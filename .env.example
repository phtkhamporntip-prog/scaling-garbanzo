# Local development
NODE_ENV=development
PORT=5000

# MongoDB Atlas connection string
# Replace <username>, <password>, and <cluster> with your actual credentials
DATABASE_URL=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/scaling-garbanzo?retryWrites=true&w=majority

# Security
SALT_ROUNDS=12
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your_refresh_jwt_secret_here
JWT_REFRESH_EXPIRES_IN=30d
JWT_STATE_SECRET=your_oauth_state_secret_here
ADMIN_BOOTSTRAP_SECRET=your_admin_bootstrap_secret_here

# Cookie settings
CLIENT_URL=http://localhost:3000
ACCESS_TOKEN_COOKIE_NAME=accessToken
REFRESH_TOKEN_COOKIE_NAME=refreshToken
COOKIE_DOMAIN=
COOKIE_SAME_SITE=lax
COOKIE_SECURE=false

# OAuth Providers
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:5000/api/v1/auth/oauth/google/callback
GOOGLE_SCOPES=openid profile email

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=http://localhost:5000/api/v1/auth/oauth/github/callback
GITHUB_SCOPES=read:user user:email

MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_CALLBACK_URL=http://localhost:5000/api/v1/auth/oauth/microsoft/callback
MICROSOFT_TENANT=common
MICROSOFT_SCOPES=openid profile email offline_access User.Read

OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_CALLBACK_URL=http://localhost:5000/api/v1/auth/oauth/oidc/callback
OIDC_AUTHORIZATION_URL=
OIDC_TOKEN_URL=
OIDC_USERINFO_URL=
OIDC_SCOPES=openid profile email

OAUTH_STATE_TTL_MINUTES=10

# App
APP_NAME=scaling-garbanzo

# -----------------------------------------------------------
# Vercel Environment Variables (set in Vercel Project Settings)
# -----------------------------------------------------------
# NODE_ENV=production
