NODE_ENV=development
PORT=5000

# MongoDB Atlas connection string
# Format: mongodb+srv://<db_username>:<db_password>@<cluster-name>.mongodb.net/<database-name>?retryWrites=true&w=majority&appName=<AppName>
# Steps to obtain:
#   1. Create a free cluster at https://cloud.mongodb.com
#   2. Under "Network Access", add 0.0.0.0/0 to allow connections from Vercel (tighten after testing)
#      Note: For production, use Vercel's static IP ranges or a VPC instead of 0.0.0.0/0
#   3. Under "Database Access", create a DB user with a username and password
#   4. Click "Connect" on your cluster, choose "Drivers", and copy the connection string
#   5. Replace <db_username> and <db_password> with your DB user credentials
DATABASE_URL=mongodb+srv://<db_username>:<db_password>@<cluster-name>.mongodb.net/scaling-garbanzo?retryWrites=true&w=majority&appName=scaling-garbanzo

SALT_ROUNDS=12
APP_NAME=scaling-garbanzo

# Generate a strong random string for JWT_SECRET (e.g. openssl rand -base64 32)
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=7d
