# JWT_EXPIRES_IN=7d
# JWT_REFRESH_SECRET=<strong-random-refresh-secret>
# JWT_REFRESH_EXPIRES_IN=30d
# JWT_STATE_SECRET=<strong-random-oauth-state-secret>
# SALT_ROUNDS=12
# APP_NAME=scaling-garbanzo
