{
  "name": "scaling-garbanzo",
  "version": "1.0.0",
  "description": "Backend for Scaling Garbanzo Trading App",
  "main": "index.js",
  "scripts": {
    "start": "node ./dist/src/index.js",
    "start-dev": "nodemon --watch src --ext ts --exec ts-node ./src/index.ts",
    "build": "tsc",
    "test:auth": "npm run build && node dist/src/scripts/auth-smoke-test.js",
    "test:auth:db": "npm run build && node dist/src/scripts/auth-db-test.js",
    "setup:init-env": "ts-node ./src/scripts/setup.ts init-env",
    "setup:generate-secrets": "ts-node ./src/scripts/setup.ts generate-secrets",
    "setup:check-env": "ts-node ./src/scripts/setup.ts check-env",
    "setup:all": "ts-node ./src/scripts/setup.ts setup-all",
    "postinstall": "prisma generate",
    "prisma:generate": "prisma generate"
  },
  "keywords": [
    "Online investing platform",
    "Scaling Garbanzo Trading App Backend"
  ],
  "author": "phtkhamporntip-prog",
  "license": "ISC",
  "devDependencies": {
    "@types/node": "^20.4.9",
    "nodemon": "^3.1.10",
    "prisma": "^5.1.1",
    "ts-node": "^10.9.1",
    "typescript": "^5.1.6"
  },
  "dependencies": {
    "@prisma/client": "^5.1.1",
    "@types/bcrypt": "^5.0.0",
    "@types/cookie-parser": "^1.4.8",
    "@types/cors": "^2.8.13",
    "@types/express": "^4.17.17",
    "@types/jsonwebtoken": "^9.0.2",
    "@types/supertest": "^6.0.3",
    "bcrypt": "^5.1.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^8.3.1",
    "http-status": "^1.7.0",
    "jsonwebtoken": "^9.0.2",
    "supertest": "^7.1.1",
    "zod": "^3.22.2"
  }
}
